<!DOCTYPE html>
<html lang="th" class="scroll-smooth">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="ร้านอาหารFavorite - อาหารไทยแท้ รสชาติต้นตำรับ สั่งออนไลน์ ส่งตรงถึงบ้าน">
  <title>
    <%= title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Prompt', 'sans-serif'],
          },
          colors: {
            dark: {
              900: '#0a0a0f',
              800: '#12121a',
              700: '#16161f',
              600: '#1c1c28'
            }
          },
          animation: {
            'hero-zoom': 'heroZoom 20s ease-in-out infinite alternate',
            'fade-up': 'fadeUp 1s ease-out forwards',
          },
          keyframes: {
            heroZoom: {
              '0%': { transform: 'scale(1.05)' },
              '100%': { transform: 'scale(1.15)' },
            },
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(30px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            }
          }
        }
      }
    }
  </script>
  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .ambient-glow {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.15;
      pointer-events: none;
      z-index: 0;
    }
  </style>
</head>

<body class="bg-gradient-to-t from-dark-900 to-gray-800 text-gray-100 selection:bg-orange-500 selection:text-white overflow-x-hidden">

  <!-- Navigation -->
  <nav id="navbar"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-dark-900/85 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-18 flex justify-between items-center py-4">
      <a href="/"
        class="text-orange-500 text-2xl font-bold flex items-center gap-2 hover:text-orange-400 hover:scale-105 transition-all">
        <span
          class="w-9 h-9 rounded-lg flex items-center justify-center text-lg shadow-[0_4px_15px_rgba(249,115,22,0.3)] bg-gradient-to-br from-orange-500 via-red-500 to-pink-500 text-white">🍽️</span>
        Favorite
      </a>
      <div class="hidden md:flex items-center gap-2">
        <a href="/" class="text-gray-100 bg-white/5 px-4 py-2 rounded-lg font-medium text-sm transition-all">หน้าแรก</a>
        <a href="/about" class="text-gray-100 bg-white/5 px-4 py-2 rounded-lg font-medium text-sm transition-all">เกี่ยวกับเรา</a>
      </div>
      <a href="/cart"
        class="flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white px-5 py-2.5 rounded-xl font-semibold text-sm transition-all shadow-[0_4px_15px_rgba(249,115,22,0.3)] hover:-translate-y-px hover:shadow-[0_6px_20px_rgba(249,115,22,0.4)]">
        🛒 ตะกร้า
        <span id="cart-count"
          class="bg-white text-orange-500 text-[11px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span>
      </a>
    </div>
  </nav>

  <!-- Menu Section -->
  <main id="menu" class="max-w-7xl mx-auto pt-32 px-6 pb-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-100 mb-3">เมนูแนะนำ</h2>
    </div>

    <!-- Category Filter -->
    <div class="flex justify-center gap-2 mb-10 flex-wrap px-6">
      <button
        class="filter-btn active px-5 py-2 rounded-full border border-orange-500 bg-orange-500 text-white text-sm font-medium transition-all shadow-[0_4px_15px_rgba(249,115,22,0.25)]"
        data-category="all">ทั้งหมด</button>
      <button
        class="filter-btn px-5 py-2 rounded-full border border-gray-700 bg-transparent text-gray-400 hover:text-white hover:bg-orange-500 hover:border-orange-500 text-sm font-medium transition-all"
        data-category="จานหลัก">จานหลัก</button>
      <button
        class="filter-btn px-5 py-2 rounded-full border border-gray-700 bg-transparent text-gray-400 hover:text-white hover:bg-orange-500 hover:border-orange-500 text-sm font-medium transition-all"
        data-category="ซุป">ซุป</button>
      <button
        class="filter-btn px-5 py-2 rounded-full border border-gray-700 bg-transparent text-gray-400 hover:text-white hover:bg-orange-500 hover:border-orange-500 text-sm font-medium transition-all"
        data-category="แกง">แกง</button>
    </div>

    <!-- Menu Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% menuItems.forEach(function(item, index) { %>
        <div
          class="menu-card bg-dark-700 border border-gray-800 rounded-2xl overflow-hidden flex flex-col transition-all duration-300 hover:border-gray-600 hover:-translate-y-1.5 hover:shadow-[0_4px_24px_rgba(0,0,0,0.4),0_0_30px_rgba(249,115,22,0.1)] group"
          data-category="<%= item.category %>" style="transition-delay: <%= index * 0.08 %>s">
          <div class="relative overflow-hidden h-[220px]">
            <img src="<%= item.image %>" alt="<%= item.name %>"
              class="w-full h-full object-cover brightness-90 transition-all duration-700 group-hover:scale-110 group-hover:brightness-100"
              loading="lazy">
            <% if (item.badge) { %>
              <span
                class="absolute top-3 left-3 bg-orange-500 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-[0_2px_10px_rgba(249,115,22,0.3)] z-10">
                <%= item.badge %>
              </span>
              <% } %>
                <span
                  class="absolute top-3 right-3 bg-dark-900/70 backdrop-blur-md text-gray-300 px-3 py-1 rounded-full text-[11px] font-medium z-10">
                  <%= item.category %>
                </span>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-orange-500 transition-colors">
              <a href="/menu/<%= item.id %>" class="focus:outline-none">
                <%= item.name %>
              </a>
            </h3>
            <p class="text-sm text-gray-500 mb-5 flex-1 line-clamp-2">
              <%= item.description %>
            </p>
            <div class="flex justify-between items-center mt-auto">
              <div class="text-xl font-bold text-orange-500">
                ฿<%= item.price %> <span class="text-sm text-gray-500 font-normal">/ จาน</span>
              </div>
              <button
                class="add-to-cart-btn flex items-center justify-center w-11 h-11 rounded-xl bg-orange-500/10 text-orange-500 text-xl transition-all duration-300 hover:bg-orange-500 hover:text-white hover:scale-110 hover:shadow-[0_4px_15px_rgba(249,115,22,0.35)]"
                title="เพิ่มลงตะกร้า" data-id="<%= item.id %>" data-name="<%= item.name %>"
                data-price="<%= item.price %>" data-image="<%= item.image %>">+</button>
            </div>
          </div>
        </div>
        <% }); %>
    </div>
  </main>


  <!-- Toast Notification -->
  <div id="toast"
    class="fixed bottom-6 right-6 bg-dark-700 border border-gray-700 rounded-xl p-4 flex items-center gap-3 shadow-[0_8px_30px_rgba(0,0,0,0.5)] translate-y-[150%] transition-transform duration-400 ease-out z-[200]">
    <div class="w-9 h-9 rounded-lg bg-green-500/15 flex items-center justify-center text-green-500 text-lg">✓</div>
    <div id="toast-message" class="text-sm text-gray-100 font-medium">เพิ่มลงตะกร้าแล้ว!</div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-gray-800 py-10 mt-16">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <span
          class="w-8 h-8 bg-gradient-to-br from-orange-500 via-red-500 to-pink-500 rounded-lg flex items-center justify-center text-white">🍽️</span>
        <span class="font-semibold text-gray-100">Favorite</span>
      </div>
      <p class="text-gray-500">&copy; 2026 ร้านโปรดของฉัน All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Navbar Scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.classList.add('bg-dark-900/95', 'shadow-[0_4px_30px_rgba(0,0,0,0.5)]');
        navbar.classList.remove('bg-dark-900/85');
      } else {
        navbar.classList.remove('bg-dark-900/95', 'shadow-[0_4px_30px_rgba(0,0,0,0.5)]');
        navbar.classList.add('bg-dark-900/85');
      }
    });

    // Fade in
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    fadeEls.forEach(el => observer.observe(el));

    // Category Filter
    const filterBtns = document.querySelectorAll('.filter-btn');
    const menuCards = document.querySelectorAll('.menu-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset styling for all buttons
        filterBtns.forEach(b => {
          b.classList.remove('active', 'bg-orange-500', 'text-white', 'border-orange-500', 'shadow-[0_4px_15px_rgba(249,115,22,0.25)]');
          b.classList.add('bg-transparent', 'text-gray-400', 'border-gray-700');
        });

        // Add active styling to clicked button
        btn.classList.add('active', 'bg-orange-500', 'text-white', 'border-orange-500', 'shadow-[0_4px_15px_rgba(249,115,22,0.25)]');
        btn.classList.remove('bg-transparent', 'text-gray-400', 'border-gray-700');

        const category = btn.dataset.category;
        menuCards.forEach(card => {
          if (category === 'all' || card.dataset.category === category) {
            card.style.display = '';
            setTimeout(() => card.classList.add('visible'), 50);
          } else {
            card.style.display = 'none';
            card.classList.remove('visible');
          }
        });
      });
    });

    // Add to Cart
    const cartBadge = document.getElementById('cart-count');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');
    let toastTimeout;

    const updateCartBadge = () => {
      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
      cartBadge.textContent = totalItems;
    };

    // Initialize cart badge
    updateCartBadge();

    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();

        const id = btn.dataset.id;
        const name = btn.dataset.name;
        const price = parseFloat(btn.dataset.price);
        const image = btn.dataset.image;

        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        const existingItem = cart.find(item => item.id === id);

        if (existingItem) {
          existingItem.quantity += 1;
        } else {
          cart.push({ id, name, price, image, quantity: 1 });
        }

        localStorage.setItem('cart', JSON.stringify(cart));
        updateCartBadge();

        // Pulse animation
        cartBadge.classList.add('scale-150');
        setTimeout(() => cartBadge.classList.remove('scale-150'), 200);

        toastMessage.textContent = `เพิ่ม "${name}" ลงตะกร้าแล้ว!`;
        toast.classList.remove('translate-y-[150%]');

        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => toast.classList.add('translate-y-[150%]'), 2500);
      });
    });
  </script>
</body>

</html>