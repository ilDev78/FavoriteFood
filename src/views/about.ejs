<!DOCTYPE html>
<html lang="th" class="scroll-smooth">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="เกี่ยวกับร้านFavorite - อาหารไทยแท้ รสชาติต้นตำรับ เปิดมากว่า 20 ปี">
  <title>
    <%= title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Prompt', 'sans-serif'],
          },
          colors: {
            dark: {
              900: '#0a0a0f',
              800: '#12121a',
              700: '#16161f',
              600: '#1c1c28'
            }
          },
          animation: {
            'fade-up': 'fadeUp 1s ease-out forwards',
          },
          keyframes: {
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(30px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            }
          }
        }
      }
    }
  </script>
  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .ambient-glow {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.15;
      pointer-events: none;
      z-index: 0;
    }
  </style>
</head>

<body class="bg-dark-900 text-gray-100 selection:bg-orange-500 selection:text-white overflow-x-hidden">

  <!-- Navigation -->
  <nav id="navbar"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-dark-900/85 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-18 flex justify-between items-center py-4">
      <a href="/"
        class="text-orange-500 text-2xl font-bold flex items-center gap-2 hover:text-orange-400 hover:scale-105 transition-all">
        <span
          class="w-9 h-9 rounded-lg flex items-center justify-center text-lg shadow-[0_4px_15px_rgba(249,115,22,0.3)] bg-gradient-to-br from-orange-500 via-red-500 to-pink-500 text-white">🍽️</span>
        Favorite
      </a>
      <div class="hidden md:flex items-center gap-2">
        <a href="/" class="text-gray-400 hover:text-white px-4 py-2 rounded-lg font-medium text-sm transition-all">หน้าแรก</a>
        <a href="/about" class="text-gray-100 bg-white/5 px-4 py-2 rounded-lg font-medium text-sm transition-all">เกี่ยวกับเรา</a>
      </div>
      <a href="/cart"
        class="flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white px-5 py-2.5 rounded-xl font-semibold text-sm transition-all shadow-[0_4px_15px_rgba(249,115,22,0.3)] hover:-translate-y-px hover:shadow-[0_6px_20px_rgba(249,115,22,0.4)]">
        🛒 ตะกร้า
        <span id="cart-count"
          class="bg-white text-orange-500 text-[11px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span>
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <header class="relative w-full min-h-[68vh] flex items-center justify-center overflow-hidden mt-18">
    <img src="/images/images bg (7).png" alt="About Hero"
      class="absolute inset-0 w-full h-full object-cover brightness-[0.75] scale-105">
    <div class="absolute inset-0 bg-gradient-to-b from-dark-900/40 via-dark-900/60 to-dark-900"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl animate-fade-up">
      <h1
        class="text-4xl sm:text-5xl md:text-7xl font-bold leading-tight mb-4 bg-gradient-to-br from-white to-gray-400 bg-clip-text">
        เรื่องราวของเรา
      </h1>
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        จากความรักในอาหารไทย สู่ร้านอาหารที่อบอุ่นที่สุดในย่านนี้
      </p>
    </div>
  </header>

  <!-- Story Section -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-5 fade-in">
        <div
          class="inline-flex items-center gap-1.5 bg-orange-500/90 text-black px-4 py-1.5 rounded-full text-sm font-medium mb-2">
          📖 เรื่องราวของเรา
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-100">กว่าจะมาเป็น<br>Favorite</h2>
        <p class="text-gray-400 leading-relaxed">
          ร้าน Favorite เริ่มต้นจากความฝันเล็กๆ ของครอบครัวคนไทย ที่อยากให้ทุกคนได้ลิ้มลอง
          รสชาติอาหารไทยแท้ๆ ที่ปรุงด้วยใจและวัตถุดิบสดใหม่每一天
        </p>
        <p class="text-gray-500 leading-relaxed">
          กว่า 20 ปีที่เรายืนหยัดในเรื่องคุณภาพ คัดสรรวัตถุดิบชั้นดีจากทุกภูมิภาคของประเทศไทย
          สืบทอดตำรับเครื่องแกงและน้ำพริกจากรุ่นสู่รุ่น เพื่อให้ทุกคำที่คุณทาน
          เต็มไปด้วยความทรงจำและรอยยิ้ม
        </p>
      </div>
      <div class="relative fade-in">
        <div class="ambient-glow bg-orange-500 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
        <img src="/images/menu-2.jpg" alt="ร้าน Favorite"
          class="w-full h-[400px] object-cover rounded-2xl border border-gray-800 shadow-[0_20px_60px_rgba(0,0,0,0.5)] relative z-10">
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="text-center mb-14 fade-in">
      <div
        class="inline-flex items-center gap-1.5 bg-orange-500/90 text-black px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        💎 สิ่งที่เราให้ความสำคัญ
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-100">ค่านิยมของเรา</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-8 text-center fade-in transition-all duration-300 hover:border-orange-500/30 hover:-translate-y-1">
        <div class="w-16 h-16 rounded-xl bg-orange-500/10 flex items-center justify-center mx-auto mb-5 text-3xl">🌿</div>
        <h3 class="text-xl font-semibold text-gray-100 mb-3">วัตถุดิบสดใหม่</h3>
        <p class="text-gray-500 text-sm leading-relaxed">คัดสรรวัตถุดิบจากแหล่งผลิตโดยตรง ส่งตรงถึงร้านทุกเช้า</p>
      </div>
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-8 text-center fade-in transition-all duration-300 hover:border-orange-500/30 hover:-translate-y-1">
        <div class="w-16 h-16 rounded-xl bg-orange-500/10 flex items-center justify-center mx-auto mb-5 text-3xl">👩‍🍳</div>
        <h3 class="text-xl font-semibold text-gray-100 mb-3">ตำรับต้นตำรับ</h3>
        <p class="text-gray-500 text-sm leading-relaxed">สืบทอดสูตรเครื่องแกงและน้ำพริกจากรุ่นสู่รุ่น</p>
      </div>
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-8 text-center fade-in transition-all duration-300 hover:border-orange-500/30 hover:-translate-y-1">
        <div class="w-16 h-16 rounded-xl bg-orange-500/10 flex items-center justify-center mx-auto mb-5 text-3xl">❤️</div>
        <h3 class="text-xl font-semibold text-gray-100 mb-3">บริการด้วยใจ</h3>
        <p class="text-gray-500 text-sm leading-relaxed">ทุกจานปรุงด้วยความใส่ใจ ให้คุณรู้สึกเหมือนทานอาหารที่บ้าน</p>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="text-center mb-14 fade-in">
      <div
        class="inline-flex items-center gap-1.5 bg-orange-500/90 text-black px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        👨‍🍳 ทีมงานของเรา
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-100">พบกับทีมผู้ปรุง</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-6 text-center fade-in">
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-orange-500 to-pink-500 flex items-center justify-center mx-auto mb-4 text-3xl shadow-[0_4px_20px_rgba(249,115,22,0.3)]">👩‍🍳</div>
        <h3 class="text-lg font-semibold text-gray-100">แม่สมใจ</h3>
        <p class="text-orange-500 text-sm mb-2">เชฟผู้ก่อตั้ง</p>
        <p class="text-gray-500 text-sm">ประสบการณ์กว่า 30 ปี หัวใจของทุกเมนูในร้าน</p>
      </div>
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-6 text-center fade-in">
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-orange-500 to-pink-500 flex items-center justify-center mx-auto mb-4 text-3xl shadow-[0_4px_20px_rgba(249,115,22,0.3)]">👨‍🍳</div>
        <h3 class="text-lg font-semibold text-gray-100">เชฟต้น</h3>
        <p class="text-orange-500 text-sm mb-2">หัวหน้าพ่อครัว</p>
        <p class="text-gray-500 text-sm">เชฟมากฝีมือ ผู้รังสรรค์เมนูใหม่ๆ อยู่เสมอ</p>
      </div>
      <div class="bg-dark-700 border border-gray-800 rounded-2xl p-6 text-center fade-in">
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-orange-500 to-pink-500 flex items-center justify-center mx-auto mb-4 text-3xl shadow-[0_4px_20px_rgba(249,115,22,0.3)]">👩‍🍳</div>
        <h3 class="text-lg font-semibold text-gray-100">ป้าอารี</h3>
        <p class="text-orange-500 text-sm mb-2">ผู้เชี่ยวชาญน้ำพริก</p>
        <p class="text-gray-500 text-sm">มากประสบการณ์ด้านน้ำพริกและเครื่องจิ้มทุกชนิด</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 pb-20 fade-in">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-orange-600 via-orange-500 to-red-500 p-12 text-center shadow-[0_20px_60px_rgba(249,115,22,0.25)]">
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">มาทานอาหารกับเราสิ</h2>
        <p class="text-white/80 mb-8 max-w-lg mx-auto">เปิดบริการทุกวัน 10:00 - 21:00 น. สามารถสั่งออนไลน์หรือมานั่งทานที่ร้านได้เลย</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/"
            class="inline-flex items-center gap-2 bg-white text-orange-600 font-semibold px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-all hover:-translate-y-px hover:shadow-[0_8px_25px_rgba(0,0,0,0.2)]">
            🍽️ ดูเมนูทั้งหมด
          </a>
          <a href="/cart"
            class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md text-white font-semibold px-8 py-3.5 rounded-xl border border-white/20 hover:bg-white/20 transition-all hover:-translate-y-px">
            🛒 สั่งเลย
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-800 py-10 mt-16">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <span
          class="w-8 h-8 bg-gradient-to-br from-orange-500 via-red-500 to-pink-500 rounded-lg flex items-center justify-center text-white">🍽️</span>
        <span class="font-semibold text-gray-100">Favorite</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/" class="text-gray-500 hover:text-gray-300 transition-colors">หน้าแรก</a>
        <a href="/about" class="text-orange-500 hover:text-orange-400 transition-colors">เกี่ยวกับเรา</a>
      </div>
      <p class="text-gray-500">&copy; 2026 ร้านโปรดของฉัน All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Navbar Scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.classList.add('bg-dark-900/95', 'shadow-[0_4px_30px_rgba(0,0,0,0.5)]');
        navbar.classList.remove('bg-dark-900/85');
      } else {
        navbar.classList.remove('bg-dark-900/95', 'shadow-[0_4px_30px_rgba(0,0,0,0.5)]');
        navbar.classList.add('bg-dark-900/85');
      }
    });

    // Fade in on scroll
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
    fadeEls.forEach(el => observer.observe(el));

    // Cart badge
    const cartBadge = document.getElementById('cart-count');
    const updateCartBadge = () => {
      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      cartBadge.textContent = cart.reduce((sum, item) => sum + item.quantity, 0);
    };
    updateCartBadge();
  </script>
</body>

</html>
